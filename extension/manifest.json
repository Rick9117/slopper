{
  "manifest_version": 3,
  "name": "Slopper (Brainrot/Slop stopper)",
  "version": "0.3",
  "description": "Tracks your time spent on Brainrot/Slop content, and stops you from watching more.",
  "permissions": ["tabs", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
"content_scripts": [
  {
    "matches": [
      "https://www.youtube.com/*",
      "https://www.instagram.com/*",
      "https://www.tiktok.com/*",
      "https://www.facebook.com/*",
      "https://twitter.com/*",
      "https://x.com/*"
    ],
    "js": ["config.js", "content.js"]
  }
]
}