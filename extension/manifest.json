
{
  "manifest_version": 3,
  "name": "Slopper (Slop/Brainrot stopper)",
  "version": "0.1",
  "description": "Tracks your time spent on Slop/Brainrot content, and stops you from watching more.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
"content_scripts": [
  {
    "matches": [
      "https://www.youtube.com/*",
      "https://www.instagram.com/*",
      "https://www.tiktok.com/*",
      "https://www.facebook.com/*",
      "https://twitter.com/*",
      "https://x.com/*"
    ],
    "js": ["content.js"]
  }
]
}